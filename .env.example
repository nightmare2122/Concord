# Copy this file to .env and fill in your actual token
# NEVER commit the .env file to git

# ── Single token for the unified Concord bot ──────────────────────────
# or create a new combined bot on the Discord Developer Portal.
BOT_TOKEN=your_bot_token_here

# ── PostgreSQL Configuration ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=concord_db
DB_USER=concord_user
DB_PASSWORD=your_password_here

# ── Application Settings ─────────────────────────────────────────────
# Path for archived task transcripts (default: ./Archives/Tasks)
ARCHIVE_PATH=./Archives/Tasks

# Set to "true" to disable the Rich TUI dashboard (headless mode)
DISABLE_TUI=false
